{
  "name": "borrow-nest",
  "version": "1.0.0",
  "description": "Community-centric peer-to-peer product borrowing platform with offline AI search",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "client-install": "cd client && npm install",
    "heroku-postbuild": "npm run client-install && cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "seed": "node seed.js"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^7.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "mern",
    "borrowing",
    "community",
    "ai",
    "ollama"
  ],
  "author": "Borrow Nest Team",
  "license": "MIT"
}
